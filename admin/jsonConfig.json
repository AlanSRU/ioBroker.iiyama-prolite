{
	"i18n": true,
	"type": "panel",
	"items": {
		"connectionType": {
			"type": "select",
			"label": "Connection Type",
			"options": [
				{
					"label": "TCP/IP (LAN)",
					"value": "tcp"
				},
				{
					"label": "Serial (RS232)",
					"value": "serial"
				}
			],
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"host": {
			"type": "text",
			"label": "IP Address",
			"hidden": "data.connectionType !== 'tcp'",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"port": {
			"type": "number",
			"label": "TCP Port",
			"hidden": "data.connectionType !== 'tcp'",
			"min": 1,
			"max": 65535,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"macAddress": {
			"type": "text",
			"label": "MAC Address",
			"placeholder": "AA:BB:CC:DD:EE:FF",
			"hidden": "data.connectionType !== 'tcp'",
			"help": "Required for Power Save Mode 3 and 4 (Wake-on-LAN enabled).",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"broadcastAddress": {
			"type": "text",
			"label": "WOL Broadcast Address",
			"placeholder": "e.g. 192.168.1.255",
			"hidden": "data.connectionType !== 'tcp'",
			"help": "Subnet broadcast address for WOL packets. If empty, derived from host IP (e.g. 192.168.1.100 to 192.168.1.255).",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"powerSaveMode": {
			"type": "select",
			"label": "Power Save Mode",
			"hidden": "data.connectionType !== 'tcp'",
			"newLine": true,
			"options": [
				{
					"label": "Mode 1: WOL off, source input wake off (cannot wake via network)",
					"value": 1
				},
				{
					"label": "Mode 2: WOL off, source input wake on (wakes on source signal only)",
					"value": 2
				},
				{
					"label": "Mode 3: WOL on, source input wake off (requires MAC address)",
					"value": 3
				},
				{
					"label": "Mode 4: WOL on, source input wake on (recommended, requires MAC address)",
					"value": 4
				}
			],
			"help": "Must match the Power Save mode on your display. Mode 1/2: WOL disabled, no network wake. Mode 3/4: WOL enabled, requires MAC address.",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"serialPort": {
			"type": "text",
			"label": "Serial Port",
			"placeholder": "/dev/ttyUSB0 or COM1",
			"hidden": "data.connectionType !== 'serial'",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"baudRate": {
			"type": "select",
			"label": "Baud Rate",
			"options": [
				{
					"label": "9600",
					"value": 9600
				},
				{
					"label": "115200 (LHxx42UHS-B1 series)",
					"value": 115200
				}
			],
			"hidden": "data.connectionType !== 'serial'",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"monitorId": {
			"type": "number",
			"label": "Monitor ID",
			"min": 1,
			"max": 255,
			"newLine": true,
			"help": "Monitor ID (1-255) as configured on the display",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"pollInterval": {
			"type": "number",
			"label": "Poll Interval (seconds)",
			"min": 5,
			"max": 300,
			"help": "Interval for polling display status",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		}
	}
}
